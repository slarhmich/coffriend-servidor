        {
          "name": "Login admin and save token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "const b = pm.response.json();",
                  "const token = b.token || (b.body && b.body.token);",
                  "pm.collectionVariables.set('adminToken', token || '');",
                  "pm.collectionVariables.set('clientToken', token || '');",
                  "pm.collectionVariables.set('staffToken', token || '');",
                  "pm.collectionVariables.set('newClientToken', token || '');",
                  "pm.environment.set('adminToken', token || '');",
                  "pm.globals.set('adminToken', token || '');",
                  "pm.test('admin token exists', function () { pm.expect(token).to.be.a('string').and.not.empty; });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
