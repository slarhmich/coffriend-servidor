        { "name": "DELETE /api/system/resetAll", "request": { "method": "DELETE", "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }], "url": "{{baseUrl}}/api/system/resetAll" } }
      ]
    },
    {
      "name": "10 Auth Cleanup",
      "item": [
        {
          "name": "POST /api/auth/logout",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Status 200 or 400', function () { pm.expect([200, 400]).to.include(pm.response.code); });"] } }],
          "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"token\": \"{{adminToken}}\"\n}" }, "url": "{{baseUrl}}/api/auth/logout" }
        }
      ]
    }
  ]
