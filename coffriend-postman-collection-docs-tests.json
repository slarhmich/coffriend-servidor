        {
          "name": "Init dynamic emails",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const s = String(Date.now());",
                  "const newClientEmail = 'testclient+' + s + '@example.com';",
                  "const newStaffEmail = 'newstaff+' + s + '@example.com';",
                  "pm.collectionVariables.set('runSuffix', s);",
                  "pm.environment.set('runSuffix', s);",
                  "pm.globals.set('runSuffix', s);",
                  "pm.collectionVariables.set('newClientEmail', newClientEmail);",
                  "pm.environment.set('newClientEmail', newClientEmail);",
                  "pm.globals.set('newClientEmail', newClientEmail);",
                  "pm.collectionVariables.set('newStaffEmail', newStaffEmail);",
                  "pm.environment.set('newStaffEmail', newStaffEmail);",
                  "pm.globals.set('newStaffEmail', newStaffEmail);",
                  "pm.test('Dynamic variables generated', function () { pm.expect(newClientEmail).to.include('@example.com'); });"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/productes"
          }
        },
        {
